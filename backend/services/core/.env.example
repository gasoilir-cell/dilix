# ── Dilix Core Service — Environment Variables ──────────────────────────────
# کپی این فایل به .env و مقادیر واقعی را جایگزین کنید.
# هیچ secret را در git commit نکنید.

# ── Service Identity ──────────────────────────────────────────────────────────
DILIX_SERVICE_NAME=core
DILIX_REGION=IR
DILIX_ENVIRONMENT=development

# ── Database ─────────────────────────────────────────────────────────────────
DILIX_DATABASE_URL=postgresql+asyncpg://dilix:dilix@localhost:5432/dilix_core
DILIX_REDIS_URL=redis://localhost:6379/0

# ── Security ─────────────────────────────────────────────────────────────────
# در production: openssl rand -hex 32
DILIX_JWT_SECRET=dev-only-change-me-in-production
DILIX_JWT_ALGORITHM=HS256
DILIX_ACCESS_TOKEN_TTL_SECONDS=900
DILIX_REFRESH_TOKEN_TTL_SECONDS=1209600

# ── Event Backbone (NATS JetStream) ──────────────────────────────────────────
DILIX_EVENT_BROKER_URL=nats://localhost:4222

# ── Payment — Bank Saman (اختیاری؛ خالی = sandbox فعال) ─────────────────────
DILIX_SAMAN_BASE_URL=
DILIX_SAMAN_TERMINAL_ID=
DILIX_SAMAN_SECRET=

# ── AI Service (dilix-ai-service / LangGraph) ─────────────────────────────────
# خالی = stub محلی فعال می‌شود
DILIX_AI_SERVICE_URL=

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
DILIX_OTEL_ENABLED=false
DILIX_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
DILIX_OTEL_SERVICE_NAME=dilix-core

# ── i18n ─────────────────────────────────────────────────────────────────────
DILIX_DEFAULT_LOCALE=fa

# ── Growth ───────────────────────────────────────────────────────────────────
DILIX_PUBLIC_APP_URL=https://dilix.app

# ── MinIO (ذخیره رسانه) ──────────────────────────────────────────────────────
DILIX_MINIO_ENDPOINT=localhost:9000
DILIX_MINIO_ACCESS_KEY=minioadmin
DILIX_MINIO_SECRET_KEY=minioadmin
DILIX_MINIO_BUCKET=dilix-media

# ── Elasticsearch ─────────────────────────────────────────────────────────────
DILIX_ELASTICSEARCH_URL=http://localhost:9200

# ── ورودِ فدراسیون (OAuth2/OIDC) ─────────────────────────────────────────────
# چند Client ID را با کاما جدا کنید (وب/iOS/اندروید).
DILIX_GOOGLE_CLIENT_IDS=
DILIX_MICROSOFT_CLIENT_IDS=
DILIX_MICROSOFT_TENANT=common
DILIX_APPLE_CLIENT_IDS=
DILIX_FACEBOOK_APP_ID=
DILIX_FACEBOOK_APP_SECRET=

# ── کدِ یک‌بارمصرف (OTP) ──────────────────────────────────────────────────────
DILIX_OTP_LENGTH=6
DILIX_OTP_TTL_SECONDS=300
DILIX_OTP_MAX_ATTEMPTS=5
# درگاهِ پیامک
DILIX_SMS_BASE_URL=
DILIX_SMS_API_KEY=
DILIX_SMS_SENDER=
# فیسبوک مسنجر (ارسالِ کد تأیید)
DILIX_FACEBOOK_PAGE_TOKEN=
