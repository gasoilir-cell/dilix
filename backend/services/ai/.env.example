# ── dilix-ai-service — نمونه‌ی متغیرهای محیطی ──
# همه با پیشوند DILIX_AI_ خوانده می‌شوند.

DILIX_AI_ENVIRONMENT=development
DILIX_AI_REGION=IR

# ── LLM (سازگار با OpenAI Chat Completions) ──
# اگر API key خالی بماند، سرویس با پاسخِ rule-based قطعی کار می‌کند (بدونِ تماسِ خارجی).
DILIX_AI_LLM_BASE_URL=https://api.openai.com/v1
DILIX_AI_LLM_API_KEY=
DILIX_AI_LLM_MODEL=gpt-4o-mini
DILIX_AI_LLM_TEMPERATURE=0.3
DILIX_AI_LLM_MAX_TOKENS=1024
DILIX_AI_LLM_TIMEOUT_SECONDS=30

# ── MCP Tool Layer → فراخوانیِ برگشتی به dilix-core ──
DILIX_AI_CORE_BASE_URL=
DILIX_AI_CORE_SERVICE_TOKEN=
DILIX_AI_MCP_TIMEOUT_SECONDS=15
