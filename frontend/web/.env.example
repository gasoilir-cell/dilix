# ── dilix-web — نمونه‌ی متغیرهای محیطی ──
# آدرسِ سرویسِ Core (سمتِ مرورگر از طریقِ پراکسیِ /api استفاده می‌شود).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Dilix
NEXT_PUBLIC_DEFAULT_LOCALE=fa

# ── ورودِ اجتماعی (Client IDهای عمومیِ سمتِ مرورگر) ──
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=
NEXT_PUBLIC_MICROSOFT_AUTHORITY=https://login.microsoftonline.com/common
NEXT_PUBLIC_APPLE_CLIENT_ID=
NEXT_PUBLIC_APPLE_REDIRECT_URI=
NEXT_PUBLIC_FACEBOOK_APP_ID=
